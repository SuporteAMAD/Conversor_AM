# Configurações do Conversor de Arquivos AM v2.0.0
# Copie este arquivo para .env e ajuste conforme necessário

# Ambiente de execução (development, production, rds)
FLASK_ENV=development

# Chave secreta do Flask (gere uma segura para produção)
# Gerar: python3 -c 'import secrets; print(secrets.token_hex(32))'
FLASK_SECRET=sua-chave-secreta-aqui-mude-em-producao

# ID do servidor (usado em ambientes com múltiplos servidores)
SERVER_ID=dev-01

# Porta de execução (padrão: 5000)
PORT=5000

# Host (0.0.0.0 = todas as interfaces, 127.0.0.1 = localhost)
HOST=0.0.0.0

# Configurações RDS (Remote Data Storage)
RDS_UPLOADS_PATH=/rds/shared/uploads
RDS_EXPORTS_PATH=/rds/shared/exports
RDS_LOGS_PATH=/rds/shared/logs

# Banco de dados (opcional, para auditoria futura)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=conversor_am
DB_USER=conversor_user
DB_PASSWORD=sua-senha-db-aqui

# Load balancer (para múltiplos servidores)
LOAD_BALANCER_URL=https://sua-aplicacao.com

# Limites de arquivo
MAX_FILE_SIZE_MB=50

# Configurações de logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/conversor_am.log

# Configurações de CORS (para APIs)
CORS_ORIGINS=*

# Modo debug (NUNCA ativar em produção)
DEBUG=False
